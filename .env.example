# SAPADARSI — Environment Variables (template)
# Salin ke .env.local lalu isi nilai asli. JANGAN commit .env.local

# Auth API
NEXT_PUBLIC_AUTH_API_URL=http://localhost:4500

# Chat API (opsional — legacy CS)
NEXT_PUBLIC_CHAT_API_URL=http://localhost:4310

# Agent apoteker (opsional)
PHARMACY_VOLT_AGENT_URL=http://127.0.0.1:1337
PHARMACY_VOLT_AGENT_NAME=DARSI Apoteker Screening
PHARMACY_VOLT_AGENT_TIMEOUT_MS=280000

# JWT Secret (wajib — ganti dengan secret kuat)
JWT_SECRET=change-me-to-a-strong-secret

# Database (wajib)
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/hospital_cs

# Demo login (set false di produksi)
NEXT_PUBLIC_DEMO_LOGIN=false

# App variant
NEXT_PUBLIC_APP_VARIANT=sapadarsi
NEXT_PUBLIC_PUBLIC_BASE_URL=http://localhost:3030
DARSI_PUBLIC_URL=http://localhost:3030

# Telegram approval (opsional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVAL_GROUP_CHAT_ID=

# Upload resep PDF
PHARMACY_PRESCRIPTION_UPLOAD_DIR=./uploads/prescriptions
PHARMACY_PRESCRIPTION_MAX_SIZE_MB=10

# LLM (sesuaikan dengan environment Anda)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=medgemma:4b
LLM_PROFILE=ollama-local-8b
CHAT_API_BASE_URL=http://127.0.0.1:11434/v1
CHAT_MODEL=llama3.1:8b
OLLAMA_ORCHESTRATOR_MODEL=llama3.1:8b
MEDGEMMA_OLLAMA_MODEL=medgemma:4b
MEDGEMMA_OLLAMA_CHAT_URL=http://127.0.0.1:11434/api/chat
