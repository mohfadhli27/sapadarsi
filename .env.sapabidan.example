# Sapabidan production — salin ke .env.production sebelum npm run build
NODE_ENV=production

NEXT_PUBLIC_APP_VARIANT=sapabidan
NEXT_PUBLIC_PUBLIC_BASE_URL=https://sapabidan.labvr.unusa.ac.id
DARSI_PUBLIC_URL=https://sapabidan.labvr.unusa.ac.id

# Salin nilai API dari .env.local sapadarsi (backend shared)
NEXT_PUBLIC_AUTH_API_URL=http://localhost:4500
NEXT_PUBLIC_CHAT_API_URL=http://localhost:4310

NEXT_PUBLIC_DEMO_LOGIN=true

# Notifikasi Telegram (salin dari .env.local sapadarsi — backend & grup sama)
TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVAL_GROUP_CHAT_ID=
TELEGRAM_DOCTOR_CHAT_ID=
TELEGRAM_MIDWIFE_CHAT_ID=
